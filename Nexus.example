})

CombatPage:AddSlider({
    Name    = "FOV",
    Min     = 50,
    Max     = 600,
    Default = 200,
    Suffix  = " px",
    Callback = function(val)
        aimbotFOV = val
    end,
})

CombatPage:AddDropdown({
    Name    = "Hit Part",
    Options = { "Head", "HumanoidRootPart", "Torso" },
    Callback = function(opt)
        aimbotPart = opt
        Notify({ Title="Hit Part", Text="Target: "..opt, Type="info", Duration=2 })
    end,
})

CombatPage:AddSection("Silent Aim")

CombatPage:AddToggle({
    Name     = "Silent Aim",
    Default  = false,
    Callback = function(state)
        Notify({ Title="Silent Aim", Text=state and "Aktif" or "Nonaktif",
                 Type=state and "success" or "danger", Duration=2 })
    end,
})

-- Aimbot loop
RunService.RenderStepped:Connect(function()
    if not aimbotEnabled then return end
    local camera = workspace.CurrentCamera
    if not camera then return end
    local closestPlayer = nil
    local closestDist   = aimbotFOV

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local target = p.Character:FindFirstChild(aimbotPart)
            if target then
                local screenPos, onScreen = camera:WorldToViewportPoint(target.Position)
                if onScreen then
                    local center = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
                    local dist   = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if dist < closestDist then
                        closestDist   = dist
                        closestPlayer = target
                    end
                end
            end
        end
    end

    if closestPlayer then
        local goal = CFrame.new(camera.CFrame.Position, closestPlayer.Position)
        camera.CFrame = camera.CFrame:Lerp(goal, 0.15)
    end
end)

-- ═══════════════════════════════════════════════
--  NOTIFIKASI SAMBUTAN
-- ═══════════════════════════════════════════════
task.delay(0.8, function()
    Notify({
        Title    = "Nexus Hub Loaded!",
        Text     = "Tekan RightShift untuk hide/show. Selamat bermain!",
        Type     = "success",
        Duration = 5,
    })
end)
