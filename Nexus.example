-- ═══════════════════════════════════════════════
--  TEMA WARNA
-- ═══════════════════════════════════════════════
local T = {
    BG_MAIN      = Color3.fromRGB(10, 10, 12),
    BG_SIDEBAR   = Color3.fromRGB(14, 14, 17),
    BG_PAGE      = Color3.fromRGB(18, 18, 22),
    BG_ELEMENT   = Color3.fromRGB(24, 24, 30),
    BG_HOVER     = Color3.fromRGB(32, 32, 40),
    BG_ACTIVE    = Color3.fromRGB(38, 38, 48),
    ACCENT       = Color3.fromRGB(110, 100, 255),
    ACCENT_DIM   = Color3.fromRGB(70,  63,  160),
    ACCENT_GLOW  = Color3.fromRGB(150, 140, 255),
    BORDER       = Color3.fromRGB(40,  40,  52),
    BORDER_B     = Color3.fromRGB(70,  70,  90),
    TEXT1        = Color3.fromRGB(235, 235, 245),
    TEXT2        = Color3.fromRGB(150, 150, 170),
    TEXT3        = Color3.fromRGB(80,  80,  100),
    SUCCESS      = Color3.fromRGB(80,  210, 130),
    WARNING      = Color3.fromRGB(255, 190, 60),
    DANGER       = Color3.fromRGB(255, 80,  80),
    TOG_ON       = Color3.fromRGB(100, 90,  255),
    TOG_OFF      = Color3.fromRGB(45,  45,  60),
    TOG_KNOB     = Color3.fromRGB(240, 240, 250),
}

-- ═══════════════════════════════════════════════
--  UTILITAS
-- ═══════════════════════════════════════════════
local function tw(obj, props, t, style, dir)
    local ok, err = pcall(function()
        TweenService:Create(obj,
            TweenInfo.new(t or 0.2, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out),
            props
        ):Play()
    end)
end

local function corner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = parent
    return c
end

local function stroke(parent, color, thick)
    local s = Instance.new("UIStroke")
    s.Color = color or T.BORDER
    s.Thickness = thick or 1
    s.Parent = parent
    return s
end

local function newLabel(parent, txt, size, color, font, xa, ya)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.Text       = txt   or ""
    l.TextSize   = size  or 13
    l.TextColor3 = color or T.TEXT1
    l.Font       = font  or Enum.Font.GothamSemibold
    l.TextXAlignment = xa or Enum.TextXAlignment.Left
    l.TextYAlignment = ya or Enum.TextYAlignment.Center
    l.Parent = parent
    return l
end

local function newFrame(parent, size, pos, color, zindex)
    local f = Instance.new("Frame")
    f.Size = size or UDim2.new(1,0,1,0)
    f.Position = pos or UDim2.new(0,0,0,0)
    f.BackgroundColor3 = color or T.BG_ELEMENT
    f.BorderSizePixel = 0
    f.ZIndex = zindex or 10
    f.Parent = parent
    return f
end

local function makeDraggable(frame, handle)
    handle = handle or frame
    local drag, dragInput, mPos, fPos = false, nil, nil, nil
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = true; mPos = i.Position; fPos = frame.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then drag = false end
            end)
        end
    end)
    handle.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement then dragInput = i end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if i == dragInput and drag then
            local d = i.Position - mPos
            frame.Position = UDim2.new(fPos.X.Scale, fPos.X.Offset + d.X, fPos.Y.Scale, fPos.Y.Offset + d.Y)
        end
    end)
end

