-- ── PAGE 1: MAIN ─────────────────────────────
local MainPage = AddPage("Main", "⬡")

MainPage:AddSection("Player")

MainPage:AddToggle({
    Name     = "God Mode",
    Desc     = "Tidak bisa mati",
    Default  = false,
    Callback = function(state)
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                if state then
                    hum.MaxHealth = math.huge
                    hum.Health    = math.huge
                end
            end
        end
        Notify({ Title="God Mode", Text= state and "Aktif" or "Nonaktif",
                 Type= state and "success" or "danger", Duration=2 })
    end,
})

MainPage:AddToggle({
    Name     = "Infinite Jump",
    Default  = false,
    Callback = function(state)
        _G.InfJump = state
        Notify({ Title="Infinite Jump", Text= state and "Aktif" or "Nonaktif",
                 Type= state and "success" or "danger", Duration=2 })
    end,
})

-- Infinite jump logic
UserInputService.JumpRequest:Connect(function()
    if _G.InfJump then
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
        end
    end
end)

MainPage:AddSlider({
    Name     = "Walk Speed",
    Min      = 16,
    Max      = 300,
    Default  = 16,
    Suffix   = " WS",
    Callback = function(val)
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed = val end
        end
    end,
})

MainPage:AddSlider({
    Name     = "Jump Power",
    Min      = 50,
    Max      = 500,
    Default  = 50,
    Suffix   = " JP",
    Callback = function(val)
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.JumpPower = val end
        end
    end,
})

MainPage:AddSection("Actions")

MainPage:AddButton({
    Name     = "Teleport ke Spawn",
    Callback = function()
        local char = LocalPlayer.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.CFrame = CFrame.new(0, 5, 0) end
        end
        Notify({ Title="Teleport", Text="Berhasil teleport ke spawn!", Type="success", Duration=3 })
    end,
})

MainPage:AddButton({
    Name     = "Reset Karakter",
    Callback = function()
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.Health = 0 end
        end
    end,
})

MainPage:AddButton({
    Name     = "Copy My Position",
    Callback = function()
        local char = LocalPlayer.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local p = hrp.Position
                local txt = string.format("X=%.1f Y=%.1f Z=%.1f", p.X, p.Y, p.Z)
                Notify({ Title="Posisi Karakter", Text=txt, Type="info", Duration=4 })
            end
        end
    end,
})

-- ── PAGE 2: VISUAL ────────────────────────────
local VisualPage = AddPage("Visual", "◈")

VisualPage:AddSection("ESP")

local espEnabled = false
local espHighlights = {}

local function clearESP()
    for _, h in ipairs(espHighlights) do pcall(function() h:Destroy() end) end
    espHighlights = {}
end

local function refreshESP()
    clearESP()
    if not espEnabled then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local ok2, hl = pcall(function()
                local h = Instance.new("SelectionBox")
                h.Adornee = p.Character
                h.Color3 = Color3.fromRGB(100,90,255)
                h.LineThickness = 0.04
                h.SurfaceTransparency = 0.85
                h.SurfaceColor3 = Color3.fromRGB(100,90,255)
                h.Parent = CoreGui
                return h
            end)
            if ok2 then table.insert(espHighlights, hl) end
        end
    end
end

VisualPage:AddToggle({
    Name     = "Player ESP",
    Default  = false,
    Callback = function(state)
        espEnabled = state
        refreshESP()
        Notify({ Title="Player ESP", Text=state and "Aktif" or "Nonaktif",
                 Type=state and "success" or "danger", Duration=2 })
    end,
})

VisualPage:AddToggle({
    Name     = "Chams (Highlight)",
    Default  = false,
    Callback = function(state)
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                pcall(function()
                    local existing = p.Character:FindFirstChildOfClass("Highlight")
                    if state and not existing then
                        local hl = Instance.new("Highlight")
                        hl.FillColor = Color3.fromRGB(100,90,255)
                        hl.OutlineColor = Color3.fromRGB(150,140,255)
                        hl.FillTransparency = 0.6
                        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                        hl.Parent = p.Character
                    elseif not state and existing then
                        existing:Destroy()
                    end
                end)
            end
        end
        Notify({ Title="Chams", Text=state and "Aktif" or "Nonaktif",
                 Type=state and "success" or "danger", Duration=2 })
    end,
})

VisualPage:AddSection("World")

VisualPage:AddToggle({
    Name     = "Fullbright",
    Default  = false,
    Callback = function(state)
        local lighting = game:GetService("Lighting")
        if state then
            lighting.Brightness = 5
            lighting.GlobalShadows = false
            lighting.FogEnd = 100000
            lighting.ClockTime = 14
        else
            lighting.Brightness = 2
            lighting.GlobalShadows = true
        end
        Notify({ Title="Fullbright", Text=state and "Aktif" or "Nonaktif",
                 Type=state and "success" or "warning", Duration=2 })
    end,
})

VisualPage:AddToggle({
    Name     = "No Fog",
    Default  = false,
    Callback = function(state)
        game:GetService("Lighting").FogEnd = state and 999999 or 100000
    end,
})

-- ── PAGE 3: MISC ─────────────────────────────
local MiscPage = AddPage("Misc", "⚙")

MiscPage:AddSection("Settings")

MiscPage:AddDropdown({
    Name    = "Game Speed",
    Options = { "Normal (1x)", "Cepat (2x)", "Lambat (0.5x)", "Beku (0x)" },
    Callback = function(opt)
        local speeds = { ["Normal (1x)"] = 1, ["Cepat (2x)"] = 2, ["Lambat (0.5x)"] = 0.5, ["Beku (0x)"] = 0 }
        local spd = speeds[opt] or 1
        workspace.Gravity = 196.2
        game:GetService("RunService"):Set3dRenderingEnabled(true)
        pcall(function() workspace:FindFirstChildOfClass("SpecialMesh") end)
        Notify({ Title="Game Speed", Text="Set ke "..opt, Type="info", Duration=2 })
    end,
})

MiscPage:AddTextbox({
    Name        = "Teleport ke Posisi",
    Placeholder = "X,Y,Z  contoh: 0,50,0",
    Callback    = function(text)
        local parts = string.split(text, ",")
        if #parts == 3 then
            local x,y,z = tonumber(parts[1]), tonumber(parts[2]), tonumber(parts[3])
            if x and y and z then
                local char = LocalPlayer.Character
                if char then
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    if hrp then hrp.CFrame = CFrame.new(x,y,z) end
                end
                Notify({ Title="Teleport", Text=string.format("Ke %.0f, %.0f, %.0f",x,y,z), Type="success", Duration=3 })
            end
        end
    end,
})

MiscPage:AddKeybind({
    Name     = "Toggle Menu",
    Default  = Enum.KeyCode.RightShift,
    Callback = function()
        Main.Visible = not Main.Visible
    end,
})

MiscPage:AddSection("Info")

local serverLabel = MiscPage:AddLabel({ Text="Server: menghitung...", Color=T.TEXT2 })
local pingLabel   = MiscPage:AddLabel({ Text="Ping: --", Color=T.TEXT2 })

-- Update info setiap 2 detik
task.spawn(function()
    while task.wait(2) do
        local plrCount = #Players:GetPlayers()
        pcall(function()
            serverLabel:Set("Players: "..plrCount.." | JobId: "..game.JobId:sub(1,8).."...")
        end)
        pcall(function()
            local stats = game:GetService("Stats")
            local ping = math.floor(stats.Network.ServerStatsItem["Data Ping"]:GetValue())
            pingLabel:Set("Ping: "..tostring(ping).." ms")
        end)
    end
end)

MiscPage:AddButton({
    Name     = "Test Notifikasi Info",
    Callback = function()
        Notify({ Title="Nexus Hub", Text="Ini contoh notifikasi info!", Type="info", Duration=3 })
    end,
})

MiscPage:AddButton({
    Name     = "Test Notifikasi Success",
    Callback = function()
        Notify({ Title="Berhasil!", Text="Operasi sukses dilakukan.", Type="success", Duration=3 })
    end,
})

